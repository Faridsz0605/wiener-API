# ImageKit credentials
# Get these from your ImageKit dashboard: https://imagekit.io/dashboard/developer/api-keys
IMAGEKIT_PUBLIC_KEY=your_public_key_here
IMAGEKIT_PRIVATE_KEY=your_private_key_here
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Authentication
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Database
# For local development with SQLite (async driver)
DATABASE_URL=sqlite+aiosqlite:///./db.sqlite3
